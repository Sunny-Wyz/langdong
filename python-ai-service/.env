# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=spare_db
DB_CHARSET=utf8mb4

# ==================== 缓存配置 ====================
REDIS_URL=redis://localhost:6379

# ==================== FastAPI 配置 ====================
FASTAPI_ENV=development
DEBUG=true
API_PORT=8001
API_HOST=0.0.0.0

# ==================== MLflow 配置（模型管理） ====================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTRY_URI=http://localhost:5000

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== Java 后端配置（回调用） ====================
JAVA_BACKEND_URL=http://localhost:8080
JAVA_API_TOKEN=your_api_token_here

# ==================== PyTorch 配置 ====================
# M1 Pro 上自动使用 MPS（Metal Performance Shaders）
# 如需禁用 MPS 用 CPU，设置为 CPU
PYTORCH_DEVICE=auto
